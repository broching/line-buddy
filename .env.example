# Convex Configuration
# Get these from your Convex dashboard at https://dashboard.convex.dev
CONVEX_DEPLOYMENT=your_convex_deployment_here
NEXT_PUBLIC_CONVEX_URL=https://your-convex-url.convex.cloud

# Clerk Authentication & Billing
# Get these from your Clerk dashboard at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL
# This comes from your JWT template in Clerk dashboard (create a template named "convex")
NEXT_PUBLIC_CLERK_FRONTEND_API_URL=https://your-clerk-frontend-api-url.clerk.accounts.dev

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# LINE Messaging API
# Get these from your LINE Developers Console: https://developers.line.biz
# Set per-organization in the app UI; these are only needed for local dev/testing
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# AI Provider — Gemini 2.5 Flash
# Get your API key from: https://aistudio.google.com/apikeys
# Set GEMINI_API_KEY in your Convex dashboard environment variables (not in .env)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Credential Encryption
# 32-byte hex string used to encrypt LINE credentials stored in Convex
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Stripe (credit top-up system)
# Get these from your Stripe dashboard at https://dashboard.stripe.com
# Set STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET in your Convex dashboard environment variables
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create one product per pack in Stripe, set price in SGD
# Pack: 1,000 credits — S$9.90
STRIPE_PRICE_ID_1000=price_...
# Pack: 5,000 credits — S$39.90
STRIPE_PRICE_ID_5000=price_...
# Pack: 15,000 credits — S$99.90
STRIPE_PRICE_ID_15000=price_...
# Pack: 50,000 credits — S$299.90
STRIPE_PRICE_ID_50000=price_...

# Your app's public URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Note: CLERK_WEBHOOK_SECRET should be set in your Convex dashboard environment variables
# Note: STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_ID_* should be set in Convex dashboard too
# Note: OPENAI_API_KEY, AI_PROVIDER, CREDENTIALS_ENCRYPTION_KEY should be set in Convex dashboard too
